@page "/cars/delete/{Id:int}"

<PageTitle>Delete Car</PageTitle>

<h3>Delete Car</h3>

@if (isLoading)
{
    <p>Loading...</p>
}
else if (!string.IsNullOrWhiteSpace(error))
{
    <div class="alert alert-danger">@error</div>

    <a href="/cars" class="btn btn-secondary">
        Back
    </a>
}
else
{
    <div class="alert alert-warning">
        Are you sure you want to delete car
        <strong>@car?.PlateNumber</strong>?
    </div>

    <button type="button"
            class="btn btn-danger"
            disabled="@isDeleting"
            @onclick="Delete">
        @(isDeleting ? "Deleting..." : "Delete")
    </button>

    <a href="/cars" class="btn btn-secondary">
        Cancel
    </a>
}