@page "/payments/create"

<PageTitle>Create Payment</PageTitle>

<h3>Create Payment</h3>

@if (isLoading)
{
    <p>Loading...</p>
}
else
{
    <div class="card">
        <div class="card-body">

            <div class="mb-3">
                <label class="form-label">Rental *</label>

                <select @bind="model.RentalId"
                        class="form-select">
                    <option value="0">-- Select Rental --</option>

                    @foreach (var rental in rentals)
                    {
                        <option value="@rental.RentalId">
                            #@rental.RentalId -
                            @rental.CustomerName -
                            @rental.PlateNumber
                        </option>
                    }
                </select>
            </div>

            <div class="mb-3">
                <label class="form-label">Payment Date *</label>

                <input type="datetime-local"
                       @bind="model.PaymentDate"
                       @bind:format="yyyy-MM-ddTHH:mm"
                       class="form-control" />
            </div>

            <div class="mb-3">
                <label class="form-label">Amount *</label>

                <input type="number"
                       step="0.01"
                       min="0.01"
                       @bind="model.Amount"
                       class="form-control" />
            </div>

            <div class="mb-3">
                <label class="form-label">Payment Method *</label>

                <select @bind="model.PaymentMethod"
                        class="form-select">
                    <option value="">-- Select Method --</option>
                    <option value="Cash">Cash</option>
                    <option value="Card">Card</option>
                    <option value="Online">Online</option>
                </select>
            </div>

            <div class="mb-3">
                <label class="form-label">Payment Status *</label>

                <select @bind="model.PaymentStatus"
                        class="form-select">
                    <option value="Pending">Pending</option>
                    <option value="Paid">Paid</option>
                </select>
            </div>

            @if (!string.IsNullOrWhiteSpace(error))
            {
                <div class="alert alert-danger">@error</div>
            }

            <button type="button"
                    class="btn btn-primary"
                    disabled="@isSaving"
                    @onclick="Save">
                @(isSaving ? "Saving..." : "Save")
            </button>

            <a href="/payments" class="btn btn-secondary">
                Cancel
            </a>

        </div>
    </div>
}