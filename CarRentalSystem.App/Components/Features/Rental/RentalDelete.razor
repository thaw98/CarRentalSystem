@page "/rentals/delete/{Id:int}"

<PageTitle>Delete Rental</PageTitle>

<h3>Delete Rental</h3>

@if (isLoading)
{
    <p>Loading...</p>
}
else if (!string.IsNullOrWhiteSpace(error))
{
    <div class="alert alert-danger">@error</div>

    <a href="/rentals" class="btn btn-secondary">
        Back
    </a>
}
else
{
    <div class="alert alert-warning">
        Are you sure you want to delete rental
        <strong>#@rental?.RentalId</strong>
        for customer
        <strong>@rental?.CustomerName</strong>
        and car
        <strong>@rental?.PlateNumber</strong>?
    </div>

    <button type="button"
            class="btn btn-danger"
            disabled="@isDeleting"
            @onclick="Delete">
        @(isDeleting ? "Deleting..." : "Delete")
    </button>

    <a href="/rentals" class="btn btn-secondary">
        Cancel
    </a>
}