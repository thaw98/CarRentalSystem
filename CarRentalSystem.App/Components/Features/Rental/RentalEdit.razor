@page "/rentals/edit/{Id:int}"

<PageTitle>Edit Rental</PageTitle>

<h3>Edit Rental</h3>

@if (isLoading)
{
    <p>Loading...</p>
}
else
{
    <div class="card">
        <div class="card-body">

            <div class="mb-3">
                <label class="form-label">Customer *</label>

                <select @bind="model.CustomerId"
                        class="form-select">
                    <option value="0">-- Select Customer --</option>

                    @foreach (var customer in customers)
                    {
                        <option value="@customer.CustomerId">
                            @customer.Name - @customer.Phone
                        </option>
                    }
                </select>
            </div>

            <div class="mb-3">
                <label class="form-label">Car *</label>

                <select @bind="model.CarId"
                        class="form-select">
                    <option value="0">-- Select Car --</option>

                    @foreach (var car in SelectableCars)
                    {
                        <option value="@car.CarId">
                            @car.PlateNumber - @car.Brand @car.Model
                            (@car.Status)
                        </option>
                    }
                </select>
            </div>

            <div class="mb-3">
                <label class="form-label">Rental Date *</label>

                <input type="datetime-local"
                       @bind="model.RentalDate"
                       @bind:format="yyyy-MM-ddTHH:mm"
                       class="form-control" />
            </div>

            <div class="mb-3">
                <label class="form-label">Return Date</label>

                <input type="datetime-local"
                       @bind="model.ReturnDate"
                       @bind:format="yyyy-MM-ddTHH:mm"
                       class="form-control" />
            </div>

            <div class="mb-3">
                <label class="form-label">Total Amount *</label>

                <input type="number"
                       step="0.01"
                       min="0"
                       @bind="model.TotalAmount"
                       class="form-control" />
            </div>

            <div class="mb-3">
                <label class="form-label">Status *</label>

                <select @bind="model.Status"
                        class="form-select">
                    <option value="Active">Active</option>
                    <option value="Completed">Completed</option>
                    <option value="Cancelled">Cancelled</option>
                </select>
            </div>

            @if (!string.IsNullOrWhiteSpace(error))
            {
                <div class="alert alert-danger">@error</div>
            }

            <button type="button"
                    class="btn btn-primary"
                    disabled="@isSaving"
                    @onclick="Save">
                @(isSaving ? "Saving..." : "Save")
            </button>

            <a href="/rentals" class="btn btn-secondary">
                Cancel
            </a>

        </div>
    </div>
}